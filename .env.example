# Name of the Baileys auth store directory. Any string works; credentials
# persist in .baileys_auth-<name>/ after the first QR pairing.
WHATSAPP_SESSION_NAME=default

# HTTP port for the StreamableHTTP transport. Pick any free high port on your
# machine (the server binds to 127.0.0.1 only). Required when running
# http-server.ts; the stdio transport ignores this.
MCP_HTTP_PORT=

# Directory where whatsapp_export_chat writes .txt exports.
EXPORT_DIR=./exports

# Soft cap the server applies to get_messages / export_chat requests.
MAX_MESSAGES_PER_REQUEST=500
